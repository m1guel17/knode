{
  "name": "knode",
  "version": "0.1.0",
  "description": "Filesystem-to-knowledge-graph pipeline. Phase 3 query & retrieval.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "test:benchmark": "RUN_BENCHMARK=1 vitest run --config vitest.integration.config.ts tests/integration/benchmark.test.ts",
    "fixtures:generate": "node scripts/generate-fixtures.mjs",
    "fixtures:benchmark": "node scripts/generate-benchmark-corpus.mjs",
    "benchmark": "tsx --env-file=.env scripts/benchmark-extraction.ts",
    "inspect:dead": "tsx --env-file=.env scripts/inspect-dead-jobs.ts",
    "eval:rag": "tsx --env-file=.env scripts/eval-rag.ts",
    "api": "tsx --env-file=.env src/index.ts --mode api",
    "start": "tsx --env-file=.env src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@hono/node-server": "^2.0.1",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.3.0",
    "bullmq": "^5.76.5",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "neo4j-driver": "^5.24.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "smol-toml": "^1.3.1",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "docx": "^9.6.1",
    "pdfkit": "^0.18.0",
    "pptxgenjs": "^3.12.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
