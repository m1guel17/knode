# Knode environment variables. Copy to .env and edit.

# --- Logging ---
NODE_ENV=development
LOG_LEVEL=info

# --- Anthropic ---
# Required for extraction + resolution. Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI (embeddings) ---
# Required for the default embedding model (text-embedding-3-small).
# Use a separate provider config in default.toml if you prefer Ollama.
OPENAI_API_KEY=

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knode-dev-password
NEO4J_DATABASE=neo4j

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Pipeline data dir ---
# Where the SQLite processing log lives.
KNODE_DATA_DIR=./data

# --- Tiered model overrides (optional) ---
# KNODE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# KNODE_RESOLUTION_MODEL=claude-sonnet-4-6

# --- Cost budget (optional) ---
# KNODE_BUDGET_PER_RUN_USD=10.0
