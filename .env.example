# Knode environment variables. Copy to .env and edit.

# --- Logging ---
NODE_ENV=development
LOG_LEVEL=info

# --- Anthropic ---
# Required for extraction + resolution. Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Embeddings provider key (pick ONE depending on [embedding] in default.toml) ---
# OpenAI for text-embedding-3-small (1536 dims):
OPENAI_API_KEY=
# Google for text-embedding-004 (768 dims) — default in this repo:
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knode-dev-password
NEO4J_DATABASE=neo4j

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Pipeline data dir ---
# Where the SQLite processing log lives.
KNODE_DATA_DIR=./data

# --- Tiered model overrides (optional) ---
# KNODE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# KNODE_RESOLUTION_MODEL=claude-sonnet-4-6

# --- Cost budget (optional) ---
# KNODE_BUDGET_PER_RUN_USD=10.0

# --- API server (Phase 3) ---
# Required for `--mode api`. Must be at least 8 chars; comparison is timing-safe.
API_TOKEN=
# Override the listen address (defaults: 127.0.0.1:3030).
# KNODE_API_HOST=0.0.0.0
# KNODE_API_PORT=3030
# Override the model that synthesizes RAG answers (defaults to claude-sonnet-4-6).
# KNODE_RAG_ANSWER_MODEL=claude-sonnet-4-6
